# ---- Supabase ----
# From https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
# Service role key — NEVER expose to the browser. Used by admin server actions (invites etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ---- OpenAI ----
OPENAI_API_KEY=sk-proj-...
# Optional model overrides
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# ---- App ----
# Full base URL, used in invite redirect links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Encryption for integrations table ----
# 32-byte hex (openssl rand -hex 32)
INTEGRATIONS_ENCRYPTION_KEY=replace-with-64-hex-chars

# ---- Optional: WP credentials can be stored in DB integrations table instead
# Only used as fallback / for initial testing
WORDPRESS_BASE_URL=https://www.knowon.de
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ---- LinkedIn (OAuth for content sync) ----
# Developer App anlegen unter https://www.linkedin.com/developers/apps
# Redirect URI eintragen: $NEXT_PUBLIC_APP_URL/api/oauth/linkedin/callback
# Products aktivieren: "Sign In with LinkedIn" + "Share on LinkedIn" (kein Review)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ---- Meta / Instagram Business (OAuth for Instagram sync) ----
# Developer App anlegen unter https://developers.facebook.com/apps/
# Redirect URI: $NEXT_PUBLIC_APP_URL/api/oauth/instagram/callback
# Braucht Instagram Business Account + verknüpfte Facebook Page
META_CLIENT_ID=
META_CLIENT_SECRET=

# ---- Optional: Brevo fallback ----
BREVO_API_KEY=
