# ---- Supabase ----
# From https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
# Service role key — NEVER expose to the browser. Used by admin server actions (create user etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ---- OpenAI ----
OPENAI_API_KEY=sk-proj-...
# Optional model overrides
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# ---- App ----
# Full base URL, used in redirect links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Encryption for integrations table ----
# 32-byte hex (openssl rand -hex 32)
INTEGRATIONS_ENCRYPTION_KEY=replace-with-64-hex-chars

# ---- Optional: WordPress fallback ----
# Only used if no credentials are saved in the integrations table.
# In normal operation, admins enter these in Settings → Integrationen.
WORDPRESS_BASE_URL=https://www.knowon.de
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ---- Optional: Brevo (newsletter) ----
BREVO_API_KEY=
